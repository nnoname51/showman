MAIN_KEYBOARD = [['🌱 Мои растения', '➕ Добавить'], ['📖 Советы', '💧 Я полил!']]
MARKUP = ReplyKeyboardMarkup(MAIN_KEYBOARD, resize_keyboard=True)

# Функция СТАРТ — вызывается кнопкой "Запустить" в Telegram
async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text(
        "Привет! Я твой помощник по растениям 🌿\nВыбери действие на кнопках ниже:", 
        reply_markup=MARKUP
    )
    return ConversationHandler.END

async def ask_add(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text("Напиши название растения для добавления:")
    return CHOOSING_PLANT_TO_ADD

async def confirm_add(update: Update, context: ContextTypes.DEFAULT_TYPE):
    name = update.message.text
    user_id = str(update.effective_user.id)
    if user_id not in user_plants: user_plants[user_id] = []
    user_plants[user_id].append({"name": name, "last_watered": "Еще не поливали"})
    save_data()
    await update.message.reply_text(f"✅ '{name}' добавлено! Что дальше?", reply_markup=MARKUP)
    return ConversationHandler.END

async def ask_care(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text("О каком растении рассказать? (Напр: Роза, Кактус)")
    return CHOOSING_PLANT_TO_CARE

async def show_care(update: Update, context: ContextTypes.DEFAULT_TYPE):
    name = update.message.text.lower()
    tip = PLANT_TIPS.get(name, "Я пока не знаю это растение.")
    await update.message.reply_text(f"📖 {name.capitalize()}: {tip}\n\nВыбери действие:", reply_markup=MARKUP)
    return ConversationHandler.END

async def ask_water(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text("Какое растение ты полил?")
    return CHOOSING_PLANT_TO_WATER

async def confirm_water(update: Update, context: ContextTypes.DEFAULT_TYPE):
    name = update.message.text.lower()
    user_id = str(update.effective_user.id)
    now = datetime.now().strftime("%d.
[23.03.2026 14:38] тимур: %m %H:%M")
    found = False
    for p in user_plants.get(user_id, []):
        if p['name'].lower() == name:
            p['last_watered'] = now
            found = True
            break
    if found: save_data()
    msg = f"💧 Записал полив для '{name}'! ✅" if found else "❌ Нет в списке."
    await update.message.reply_text(f"{msg}\nВыбери действие:", reply_markup=MARKUP)
    return ConversationHandler.END

async def show_my_plants(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = str(update.effective_user.id)
    plants = user_plants.get(user_id, [])
    res = "🌿 Список:\n" + "\n".join([f"• {p['name']} (Полив: {p['last_watered']})" for p in plants]) if plants else "Твой сад пуст."
    await update.message.reply_text(f"{res}\n\nВыбери действие:", reply_markup=MARKUP)
    return ConversationHandler.END

