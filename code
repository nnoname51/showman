    TOKEN = "8700856760:AAF_IxRtp7E8yYqY1x4elJhwZvbp5JYKPz4"
    app = ApplicationBuilder().token(TOKEN).connect_timeout(30).read_timeout(30).build()

    conv_handler = ConversationHandler(
        entry_points=[
            CommandHandler("start", start),
            MessageHandler(filters.Regex('^➕ Добавить$'), ask_add),
            MessageHandler(filters.Regex('^📖 Советы$'), ask_care),
            MessageHandler(filters.Regex('^💧 Я полил!$'), ask_water),
